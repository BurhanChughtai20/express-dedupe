{
  "name": "express-dedupe",
  "version": "1.0.0",
  "description": "In-flight request deduplication middleware for Express",
  "author": "",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev":   "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint":  "tsc --noEmit"
  },
  "peerDependencies": {
    "express": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "express": { "optional": false }
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "tsup":           "^8.0.0",
    "typescript":     "^5.0.0",
    "express":        "^4.21.0"
  }
}