{
  "name": "express-dedupe",
  "version": "1.0.4",
  "description": "Express middleware to deduplicate concurrent identical HTTP requests — prevents thundering herd, merges in-flight requests, boosts Node.js API performance with TypeScript support",
  "keywords": [
    "express",
    "express-middleware",
    "middleware",
    "dedupe",
    "deduplication",
    "dedup",
    "request-coalescing",
    "request-merging",
    "concurrent-requests",
    "in-flight-requests",
    "thundering-herd",
    "thundering-herd-protection",
    "cache",
    "request-cache",
    "performance",
    "nodejs",
    "node",
    "typescript",
    "trie",
    "url-pattern",
    "rate-limiting",
    "api-optimization",
    "http-middleware",
    "request-deduplication",
    "prevent-duplicate-requests"
  ],
  "author": {
    "name": "Muhammad Burhan Chughtai",
    "url": "https://github.com/BurhanChughtai20"
  },
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "homepage": "https://github.com/BurhanChughtai20/express-dedupe",
  "repository": {
    "type": "git",
    "url": "https://github.com/BurhanChughtai20/express-dedupe.git"
  },
  "bugs": {
    "url": "https://github.com/BurhanChughtai20/express-dedupe/issues"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "tsc --noEmit",
    "snyk:test": "snyk test",
    "snyk:protect": "@snyk/protect",
    "prepublishOnly": "npm run build && npm run lint && npm run snyk:test"
  },
  "peerDependencies": {
    "express": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": false
    }
  },
  "devDependencies": {
    "@snyk/protect": "^1.1304.0",
    "@types/express": "^5.0.0",
    "express": "^4.21.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
