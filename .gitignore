# ================================
# express-dedupe — .gitignore
# ================================


# ================================
# Node.js — Dependencies
# ================================
node_modules/
.npm
.yarn/
yarn.lock
package-lock.json


# ================================
# TypeScript — Compiled Output
# ================================
dist/
build/
out/
*.js.map
*.d.ts.map
# Keep these — only ignore compiled
!src/**/*.ts


# ================================
# TypeScript Cache
# ================================
*.tsbuildinfo
.tsbuildinfo
tsconfig.tsbuildinfo


# ================================
# NPM Package — Publish Artifacts
# ================================
# Yeh files npm publish karte waqt banti hain
*.tgz
*.tar.gz
.npmrc
.npmignore


# ================================
# Environment Variables — SECRETS
# ================================
# Kabhi bhi git mein push mat karo
.env
.env.local
.env.development
.env.test
.env.production
.env.staging
*.env


# ================================
# Test Coverage Reports
# ================================
coverage/
.coverage
*.lcov
.nyc_output/
junit.xml
test-results/


# ================================
# Logs
# ================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*


# ================================
# OS Generated Files
# ================================

# MacOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
Icon?

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msm
*.msp
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*


# ================================
# IDE / Editor Files
# ================================

# VSCode
.vscode/
!.vscode/extensions.json
!.vscode/settings.json

# JetBrains (WebStorm, IntelliJ)
.idea/
*.iml
*.iws
*.ipr
.idea_modules/

# Vim
*.swp
*.swo
*~
Session.vim
.netrwhist

# Sublime Text
*.tmlanguage.cache
*.tmPreferences.cache
*.stTheme.cache
*.sublime-workspace

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc


# ================================
# Debugging
# ================================
.node_repl_history
*.pid
*.pid.lock
*.seed


# ================================
# Optional — Benchmarks & Profiling
# ================================
benchmark/results/
*.cpuprofile
*.heapsnapshot


# ================================
# Temporary Files
# ================================
tmp/
temp/
.temp/
.tmp/
*.tmp
*.bak
*.backup
*.orig